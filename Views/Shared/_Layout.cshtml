<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QMS Dashboard</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" rel="stylesheet" />

    <!-- Custom CSS -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body>
@{
    var userEmail = Context.Session.GetString("UserEmail");
}

<!-- Navbar (show only if user logged in) -->
@if (!string.IsNullOrEmpty(userEmail))
{
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">

            <!-- Brand -->
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                QMS Dashboard
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <!-- LEFT MENU (Modules) -->
                <ul class="navbar-nav me-auto">

                    <!-- Dashboard -->
                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Home"
                           asp-action="Index">
                            <i class="fa-solid fa-house me-1"></i>
                            Dashboard
                        </a>
                    </li>

                    <!-- Requests -->
                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Requests"
                           asp-action="Index">
                            <i class="fa-solid fa-list-check me-1"></i>
                            Requests
                        </a>
                    </li>

                    <!-- IMS ASSESSMENT (NEW STANDALONE MODULE) -->
                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="IMSAssessment"
                           asp-action="Create">
                            <i class="fa-solid fa-clipboard-check me-1"></i>
                            IMS Assessment
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white" href="@Url.Action("Index", "IMSAssessment")">
                            <i class="fa-solid fa-clipboard-list me-1"></i> IMS Asssessment Dashboard
                        </a>
                    </li>
                </ul>

                <!-- RIGHT MENU (User Actions) -->
                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">
                        <span class="nav-link text-white">
                            <i class="fa-solid fa-user me-1"></i>
                            @userEmail
                        </span>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-white"
                           asp-controller="Account"
                           asp-action="Logout">
                            <i class="fa-solid fa-right-from-bracket me-1"></i>
                            Logout
                        </a>
                    </li>

                </ul>

            </div>
        </div>
    </nav>
}

<!-- Main Content -->
<main class="py-4">
    @RenderBody()
</main>

<!-- Footer -->
<footer class="bg-light text-center py-3 mt-auto border-top">
    <div class="container">
        <small>&copy; @DateTime.Now.Year KTC Group. All Rights Reserved.</small>
    </div>
</footer>

<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@RenderSection("Scripts", required: false)

</body>
</html>