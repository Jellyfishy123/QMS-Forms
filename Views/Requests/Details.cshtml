@model QMSForms.Models.Request

@{
    ViewData["Title"] = "Request Details";
    bool canEditDraft = Model.Status == QMSForms.Models.RequestStatus.Draft;
    bool canEditAcknowledged = Model.Status == QMSForms.Models.RequestStatus.Acknowledged;
    bool canEditApproval = Model.Status == QMSForms.Models.RequestStatus.Completed;
    bool canEditClosure = Model.Status == QMSForms.Models.RequestStatus.Approved;
}

<div class="container my-4">
    <h2 class="mb-3">@Model.Title</h2>

    <!-- Status Badge -->
    <div class="mb-4">
        <label>Status:</label>
        <span class="badge
            @(Model.Status == QMSForms.Models.RequestStatus.Draft ? "bg-danger" :
              Model.Status == QMSForms.Models.RequestStatus.Acknowledged ? "bg-warning text-dark" :
              Model.Status == QMSForms.Models.RequestStatus.Completed ? "bg-info text-dark" :
              Model.Status == QMSForms.Models.RequestStatus.Approved ? "bg-success" :
              "bg-secondary")">
            @Model.Status
        </span>
    </div>

    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />

        <!-- ===========================
             DRAFT / REQUEST DETAILS
        =========================== -->
        <div class="card mb-4 shadow-sm p-4">
        <h4 class="mb-3">Request Details</h4>

        <div class="mb-3">
            <label asp-for="Location" class="form-label"></label>
            <input asp-for="Location" class="form-control" readonly="@(canEditDraft ? null : "readonly")" />
        </div>

        <div class="mb-3">
            <label asp-for="PersonInCharge" class="form-label">Person In Charge (PIC)</label>
            @if (canEditDraft)
            {
                <select name="PersonInCharge" class="form-select" required>
                    <option value="">-- Please select --</option>
                    @foreach (var pic in (string[])ViewBag.PICs)
                    {
                        <option value="@pic">@pic</option>
                    }
                </select>
            }
            else
            {
                <input asp-for="PersonInCharge" class="form-control" readonly />
            }
        </div>

        <div class="mb-3">
            <label asp-for="NonConformityHighlighted" class="form-label">Non-Conformity Highlighted</label>
            @if (canEditDraft)
            {
                <select asp-for="NonConformityHighlighted" class="form-select"
                        asp-items="@(new SelectList(ViewBag.NonConformityHighlighted))">
                    <option value="">-- Please select --</option>
                </select>
            }
            else
            {
                <input asp-for="NonConformityHighlighted" class="form-control" readonly />
            }
        </div>

        <div class="mb-3">
            <label asp-for="NonConformityRelatedTo" class="form-label">Non-Conformity Related To</label>
            @if (canEditDraft)
            {
                <select asp-for="NonConformityRelatedTo" class="form-select"
                        asp-items="@(new SelectList(ViewBag.NonConformityRelatedTo))">
                    <option value="">-- Please select --</option>
                </select>
            }
            else
            {
                <input asp-for="NonConformityRelatedTo" class="form-control" readonly />
            }
        </div>

        <div class="mb-3">
            <label asp-for="DescriptionOfNonConformity" class="form-label">Description of Non-Conformity</label>
            <textarea asp-for="DescriptionOfNonConformity" class="form-control" rows="3"
                    readonly="@(canEditDraft ? null : "readonly")"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="DesignatedPersonToClose" class="form-label">Designated Person To Close</label>
            @if (canEditDraft)
            {
                <select asp-for="DesignatedPersonToClose" class="form-select"
                        asp-items="@(new SelectList(ViewBag.DesignatedPersonToClose))">
                    <option value="">-- Please select --</option>
                </select>
            }
            else
            {
                <input asp-for="DesignatedPersonToClose" class="form-control" readonly />
            }
        </div>

        @if (canEditDraft)
        {

            <div class="d-flex justify-content-end mt-3">                    
                <button formaction="/Requests/Create" type="submit" class="btn btn-primary btn-sm px-4">
                    Submit Draft
                </button>
            </div>
        }
    </div>


        <!-- ===========================
             ACKNOWLEDGED / ROOT CAUSE
        =========================== -->
        @if (Model.Status >= QMSForms.Models.RequestStatus.Acknowledged)
        {
            <div class="card mb-4 shadow-sm p-4">
                <h4 class="mb-3">Root Cause & Corrective Action</h4>

                <div class="mb-3">
                    <label>Description of Root Cause</label>
                    <textarea name="DescriptionOfRootCause" class="form-control" rows="3" @(canEditAcknowledged ? "" : "readonly")>@Model.DescriptionOfRootCause</textarea>
                </div>

                <div class="mb-3">
                    <label>Type of Root Cause</label>
                    @if (canEditAcknowledged)
                    {
                        <select name="TypeOfRootCause" class="form-select" required>
                            <option value="" disabled selected>-- Please select --</option>
                            @foreach (string type in (string[])ViewBag.TypeOfRootCauseOptions)
                            {
                                <option value="@type" selected="@(Model.TypeOfRootCause == type)">
                                    @type
                                </option>                            
                            }
                        </select>
                    }
                    else
                    {
                        <input class="form-control" value="@Model.TypeOfRootCause" readonly />
                    }
                </div>

                <div class="mb-3">
                    <label>PM / CM</label>
                    @if (canEditAcknowledged)
                    {
                        <select name="PMOrCM" class="form-select" required>
                            <option value="" disabled selected>-- Please select --</option>
                            @foreach (string pm in (string[])ViewBag.PMOrCMs)
                            {
                            <option value="@pm" selected="@(Model.PMOrCM == pm)">
                                @pm
                            </option>                            }
                        </select>
                    }
                    else
                    {
                        <input class="form-control" value="@Model.PMOrCM" readonly />
                    }
                </div>

                <div class="mb-3">
                    <label>Corrective / Preventive Action</label>
                    <textarea name="CorrectivePreventiveAction" class="form-control" rows="3" @(canEditAcknowledged ? "" : "readonly")>@Model.CorrectivePreventiveAction</textarea>
                </div>

                @if (canEditAcknowledged)
                {
                    <div class="d-flex justify-content-end mt-3">
                        <button formaction="/Requests/UpdateAcknowledged" type="submit" class="btn btn-primary btn-sm px-4">Submit Root Cause</button>
                    </div>
                }
            </div>
        }

        <!-- ===========================
             COMPLETED / APPROVAL
        =========================== -->
        @if (Model.Status >= QMSForms.Models.RequestStatus.Completed)
        {
            <div class="card mb-4 shadow-sm p-4">
                <h4 class="mb-3">PM / CM Approval</h4>

                <div class="mb-3">
                    <label>Decision</label>
                    @if (canEditApproval)
                    {
                        <select name="ApprovalDecision" class="form-select" required>
                            <option value="" disabled selected>-- Please select --</option>
                            <option value="Approve">Approve</option>
                            <option value="Reject">Reject</option>
                        </select>
                    }
                    else
                    {
                        <input class="form-control" value="@Model.ApprovalDecision" readonly />
                    }
                </div>

                <div class="mb-3">
                    <label>Comments</label>
                    <textarea name="ApprovalComments" class="form-control" rows="3" @(canEditApproval ? "" : "readonly")>@Model.ApprovalComments</textarea>
                </div>

                @if (canEditApproval)
                {
                    <div class="d-flex justify-content-end mt-3">                    
                        <button formaction="/Requests/ApproveRequest" type="submit" class="btn btn-primary btn-sm px-4">Submit Approval</button>
                    </div>
                }
            </div>
        }

        <!-- ===========================
             APPROVED / CLOSURE
        =========================== -->
        @if (Model.Status >= QMSForms.Models.RequestStatus.Approved)
        {
            <div class="card mb-4 shadow-sm p-4">
                <h4 class="mb-3">Closure</h4>
                    <div class="mb-3">
                        <label>Closure Comments</label>
                        <textarea name="ClosureComments" class="form-control" rows="3" @(canEditClosure ? "" : "readonly")>@Model.ClosureComments</textarea>
                    </div>

                @if (canEditClosure)
                {
                    <div class="d-flex justify-content-end mt-3">                                        
                    <button formaction="/Requests/CloseRequest" type="submit" class="btn btn-primary btn-sm px-4">Submit Closure</button>
                </div>
                }
            </div>
        }
    </form>

    <!-- DELETE BUTTON -->
    <form asp-action="Delete" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="d-flex justify-content-end mt-4">
            <button type="submit" class="btn btn-outline-danger btn-sm px-4"
                    onclick="return confirm('Are you sure you want to delete this request?');">
                Delete Request
            </button>
        </div>
    </form>
</div>

@if (Model.Status == QMSForms.Models.RequestStatus.Closure)
{
    <div class="mt-3 d-flex gap-2">
        <!-- Export PDF Button -->
        <form method="get" asp-action="ExportClosedRequestPdf">
            <button type="submit" class="btn btn-danger btn-lg">
                <i class="fa-solid fa-file-pdf me-2"></i>Export PDF
            </button>
        </form>

        <!-- Export Excel Button -->
        <form method="get" asp-action="ExportClosedRequestExcel">
            <button type="submit" class="btn btn-success btn-lg">
                <i class="fa-solid fa-file-excel me-2"></i>Export Excel
            </button>
        </form>
    </div>

    <style>
        .btn-danger {
            background-color: #d9534f;
            border-color: #d43f3a;
        }

        .btn-danger:hover {
            background-color: #c9302c;
            border-color: #ac2925;
        }

        .btn-success {
            background-color: #28a745;
            border-color: #218838;
        }

        .btn-success:hover {
            background-color: #218838;
            border-color: #1e7e34;
        }

        .fa-file-pdf {
            color: white;
        }

        .fa-file-excel {
            color: white;
        }
    </style>

}


<style>
    .card { border-radius: 12px; background-color: #ffffff; }
    h4 { font-weight: 600; color: #495057; }
    .form-control, .form-select, textarea { border-radius: 8px; }
    .btn { border-radius: 8px; font-weight: 600; }
    .badge { font-size: 1rem; }
</style>
